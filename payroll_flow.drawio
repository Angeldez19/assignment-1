  <diagram id="payroll-flow-1" name="Payroll Flow">
    <![CDATA[
    <mxGraphModel dx="1000" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Start -->
        <mxCell id="2" value="Start" style="ellipse;whiteSpace=wrap;html=1;fillColor=#79C7C5;strokeColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="200" y="20" width="120" height="60" as="geometry"/>
        </mxCell>

        <!-- Welcome -->
        <mxCell id="3" value="Welcome\nWelcome to my Weekly Payroll program!!" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F6F7D9;strokeColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="140" y="110" width="240" height="60" as="geometry"/>
        </mxCell>

        <!-- Prompt/Input blocks -->
        <mxCell id="4" value="Prompt: Enter employee ID" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="120" y="200" width="280" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="5" value="Input: employeeID" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="140" y="250" width="240" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="6" value="Prompt: Enter hours worked" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="120" y="300" width="280" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="7" value="Input: employeeHours" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="140" y="340" width="240" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="8" value="Prompt: Enter hourly rate" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="120" y="380" width="280" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="9" value="Input: USDPerHour" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="140" y="420" width="240" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="10" value="Prompt: Enter federal withholding rate (%)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="80" y="460" width="360" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="11" value="Input: federalwithholdingRatePercent" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="140" y="500" width="240" height="30" as="geometry"/>
        </mxCell>

        <!-- Calculations -->
        <mxCell id="12" value="Do Calculations\n- grosspayUSD = employeeHours * USDPerHour\n- decimalWithholdingRate = federalwithholdingRatePercent / 100.0\n- federalTaxWithholdingUSD = grosspayUSD * decimalWithholdingRate\n- netPayUSD = grosspayUSD - federalTaxWithholdingUSD" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EFEFEF;strokeColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="80" y="550" width="360" height="160" as="geometry"/>
        </mxCell>

        <!-- Output Heading -->
        <mxCell id="13" value="Your Payroll Summary:" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FDEBD0;strokeColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="140" y="730" width="240" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="14" value="Gross Pay: $grosspayUSD" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="140" y="780" width="240" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="15" value="Federal Tax Withholding: $federalTaxWithholdingUSD" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="80" y="820" width="360" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="16" value="Net Pay: $netPayUSD" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="140" y="860" width="240" height="30" as="geometry"/>
        </mxCell>

        <!-- End -->
        <mxCell id="17" value="End\nThank you for using my Weekly Payroll program!!" style="ellipse;whiteSpace=wrap;html=1;fillColor=#79C7C5;strokeColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="200" y="920" width="240" height="60" as="geometry"/>
        </mxCell>

